# === LLM Providers ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Primary LLM provider: "anthropic" | "openai"
LLM_PROVIDER=anthropic

# Model selection per tier (cost optimization)
LLM_MODEL_HEAVY=claude-opus-4-6          # Complex reasoning, orchestration
LLM_MODEL_STANDARD=claude-sonnet-4-6     # General agent tasks
LLM_MODEL_LIGHT=claude-haiku-4-5-20251001 # Simple lookups, routing

# === Redis ===
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=3600

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./data/sqlite/support.db
# For production: postgresql+asyncpg://user:pass@host/db

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production-use-secrets-manager
API_DEBUG=false

# === Rate Limiting ===
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=500
RATE_LIMIT_BURST=10

# === Cost Control ===
COST_BUDGET_DAILY_USD=50.0
COST_ALERT_THRESHOLD_USD=40.0
MAX_TOKENS_PER_REQUEST=4096
MAX_CONTEXT_TOKENS=100000

# === Memory ===
MAX_SHORT_TERM_MESSAGES=20
LONG_TERM_SEARCH_TOP_K=5
EMBEDDING_DIM=1536

# === Observability ===
LOG_LEVEL=INFO
PROMETHEUS_PORT=9090
ENVIRONMENT=development   # development | staging | production

# === Agent Behaviour ===
MAX_AGENT_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=60
ESCALATION_CONFIDENCE_THRESHOLD=0.4
